# Environment Variables for DataSynchronizationTool
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Configuration Database (stores sync configurations)
DB_CONFIG_URL=jdbc:mysql://localhost:3306/sync_config_db?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_CONFIG_USERNAME=root
DB_CONFIG_PASSWORD=your_secure_password

# Primary Sync Database (source/target for synchronization)
DB_PRIMARY_URL=jdbc:mysql://localhost:3306/primary_db?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_PRIMARY_USERNAME=root
DB_PRIMARY_PASSWORD=your_secure_password

# Secondary Sync Database (source/target for synchronization)
DB_SECONDARY_URL=jdbc:mysql://localhost:3306/secondary_db?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_SECONDARY_USERNAME=root
DB_SECONDARY_PASSWORD=your_secure_password
